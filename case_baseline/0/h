FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      h;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -2 0 0 0 0];

// Cp * 300 K  ≈ 3.0e5 J/kg
internalField   uniform 3.0e5;

boundaryField
{
    inlet
    {
        type        fixedValue;
        value       uniform 3.0e5;   // 300 K at inlet
    }

    outlet
    {
        type        zeroGradient;
    }

    walls
    {
        type        zeroGradient;
    }

    senPam
    {
        type        zeroGradient;
    }
}

