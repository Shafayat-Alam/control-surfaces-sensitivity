FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      p;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [1 -1 -2 0 0 0 0];

internalField   uniform 101325;   // Pa

boundaryField
{
    inlet
    {
        type        fixedValue;
        value       uniform 101325;     // static pressure
    }

    outlet
    {
        type        zeroGradient;
    }

    walls
    {
        type        zeroGradient;       // OK for slip walls
    }

    senPam
    {
        type        zeroGradient;       // OK because U has noSlip here
    }
}

