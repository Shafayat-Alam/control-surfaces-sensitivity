FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      thermophysicalProperties;
}

thermoType
{
    type            heRhoThermo;
    mixture         pureMixture;
    transport       const;          // <-- CHANGED from sutherland
    thermo          hConst;
    equationOfState perfectGas;
    specie          specie;
    energy          sensibleEnthalpy;
}

mixture
{
    specie
    {
        nMoles      1;
        molWeight   28.97;      // air
    }

    thermodynamics
    {
        Cp          1005;       // J/(kg·K)
        Hf          0;
    }

    transport
    {
        mu          1.8e-5;     // Pa·s (dynamic viscosity of air)
        Pr          0.7;        // Prandtl number
    }
}


