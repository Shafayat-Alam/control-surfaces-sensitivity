FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     rhoSimpleFoam;

startFrom       startTime;

startTime       0;

stopAt          endTime;

endTime         5;

deltaT          4e-2;      // was 1e-4 before

maxDeltaT       4e-1;  

writeControl    timeStep;

writeInterval 1;

adjustTimeStep  yes;

purgeWrite      0;

writeFormat     binary;

writePrecision  6;

writeCompression off;

timeFormat      general;

maxCo           0.5;

timePrecision   6;

graphFormat     raw;

runTimeModifiable true;

functions
{
    forces
    {
        type    forces;
        libs    ("libforces.so");

        patches ("senPam");

        rho     rho;
        CofR    (0 0 0);
    }

    forceCoeffs
    {
        type            forceCoeffs;
        libs            ("libforces.so");

        patches         ("senPam");

        rho             rho;        // required in v2412
        rhoInf          1.225;      // you asked for this — now valid

        dragDir    (1 0 0);
        liftDir    (0 1 0);
        pitchAxis  (0 1 0);


        CofR            (0 0 0);

        magUInf 238;
        Aref   0.01824;     // frontal area, m^2
        lRef   2.4384;      // rocket length, m

    }

}




