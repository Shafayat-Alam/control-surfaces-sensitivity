FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      snappyHexMeshDict;
}

castellatedMesh true;
snap            true;
addLayers       false;   // can be turned on later if you want BL layers

// ==========================================================================
// GEOMETRY
// ==========================================================================
geometry
{
    baseline.stl
    {
        type triSurfaceMesh;
        name senPam;
    }
}

// ==========================================================================
// CASTELLATED MESH CONTROLS  (HIGH RESOLUTION)
// ==========================================================================
castellatedMeshControls
{
    // allow a lot of cells
    maxLocalCells         2e6;
    maxGlobalCells        2e7;
    minRefinementCells    20;
    nCellsBetweenLevels   2;

    // sharp feature capture
    features
    (
        {
            file "baseline.eMesh";
            level 4;          // fine edge refinement
        }
    );

    allowFreeStandingZoneFaces true;

    // strong surface refinement on fin
    refinementSurfaces
    {
        senPam
        {
            // (far-field level, near-surface level)
            level (3 5);      // coarse in far field, very fine at fin
            patchInfo
            {
                type wall;
            }
        }
    }

    // wake refinement box downstream of the fin
    refinementRegions
    {
        wakeBox
        {
            mode inside;
            levels ((4 4));   // fine wake
            box
            {
                type searchableBox;
                // adjust if needed, but this matches your rotated domain scale
                min (0   -20 -20);
                max (80   20  20);
            }
        }
    }

    resolveFeatureAngle    25;
    locationInMesh         (0 0 10);
}

// ==========================================================================
// SNAP CONTROLS  (AGGRESSIVE BUT STABLE)
// ==========================================================================
snapControls
{
    nSmoothPatch           15;
    nSmoothInternal        5;
    nSmoothSurfaceNormals  5;

    tolerance              1.0;
    nSolveIter             120;
    nRelaxIter             10;

    explicitFeatureSnap    true;
    implicitFeatureSnap    true;
    multiRegionFeatureSnap true;

    snapTol                0.95;
    detectNearSurfaces     snap;
}

// ==========================================================================
// ADD LAYERS (OFF, BUT CONFIG READY)
// ==========================================================================
addLayersControls
{
    relativeSizes          true;
    expansionRatio         1.1;
    finalLayerThickness    0.2;
    minThickness           0.05;
    nGrow                  0;
    layers                 {};
}

// ==========================================================================
// MESH QUALITY (STRICTER)
// ==========================================================================
meshQualityControls
{
    maxNonOrtho            65;
    maxBoundarySkewness    4;
    maxInternalSkewness    4;
    maxConcave             80;

    minVol                 1e-14;
    minTetQuality          1e-10;
    minArea                1e-13;
    minTwist               0.02;
    minDeterminant         0.0005;
    minFaceWeight          0.02;
    minVolRatio            0.01;
    minTriangleTwist       0.02;

    nSmoothScale           6;
    errorReduction         0.7;
    relaxed                true;
    nRelaxIter             8;
}

mergeTolerance 1e-8;

