FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      thermophysicalProperties;
}

thermoType
{
    type            hePsiThermo;
    mixture         pureMixture;
    transport       const;
    thermo          hConst;
    equationOfState perfectGas;
    specie          specie;
    energy          sensibleEnthalpy;   // ✅ THIS IS WHAT WE WANT
}

mixture
{
    specie
    {
        molWeight       28.96;            // kg/kmol (air)
    }

    thermodynamics
    {
        Cp              1004.5;           // J/(kg K)
        Hf              0;                // reference enthalpy (safe)
    }

    transport
    {
        mu              1.8e-5;           // dynamic viscosity (Pa·s) — REQUIRED for no-slip
        Pr              0.72;             // Prandtl number for air
    }
}

