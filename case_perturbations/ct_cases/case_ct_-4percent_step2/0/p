FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      p;
}

dimensions      [1 -1 -2 0 0 0 0];

internalField uniform 101325;

boundaryField
{
    inlet
    {
        type zeroGradient;   // because U is fixed
    }

    outlet
    {
        type fixedValue;
        value uniform 101325;   // ambient static pressure
    }


    walls
    {
        type            zeroGradient;     // slip walls → no normal gradient of p
    }

    senPam
    {
        type            zeroGradient;     // solid fin
    }
}

