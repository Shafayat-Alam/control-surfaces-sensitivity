FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      fvSchemes;
}

// ======================================================================
// Time derivatives
// ======================================================================
ddtSchemes
{
    default         backward;          // stable 2nd order
}

// ======================================================================
// Gradient schemes
// ======================================================================
gradSchemes
{
    default         Gauss linear;      // standard cell-centred gradient
}

// ======================================================================
// Divergence schemes (rhoPimpleFoam + sensibleEnthalpy h)
// ======================================================================
divSchemes
{
    // Safe default for anything not listed
    default                         none;

    // Momentum
    div(phi,U)                      Gauss limitedLinearV 1;

    // Enthalpy (energy variable)
    div(phi,h)                      Gauss limitedLinear 1;

    // Kinetic energy
    div(phi,K)                      Gauss limitedLinear 1;

    // Pressure work
    div(phiv,p)                     Gauss limitedLinear 1;

    // Viscous stress term
    div(((rho*nuEff)*dev2(T(grad(U)))))  Gauss linear;
}

// ======================================================================
// Laplacian schemes
// ======================================================================
laplacianSchemes
{
    default         Gauss linear corrected;
}

// ======================================================================
// Interpolation schemes
// ======================================================================
interpolationSchemes
{
    default         linear;
}

// ======================================================================
// Normal gradient schemes
// ======================================================================
snGradSchemes
{
    default         corrected;
}

