FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      fvSolution;
}

solvers
{
    // Pressure & density
    "(p|rho)"
    {
        solver          GAMG;
        tolerance       1e-7;
        relTol          0.01;
        smoother        DICGaussSeidel;
        nPreSweeps      0;
        nPostSweeps     2;
        nFinestSweeps   2;
    }

    "(p|rho)Final"
    {
        $p;
        relTol          0;
    }

    // Velocity & ENTHALPY (h)
    "(U|h|k|nuTilda)"
    {
        solver          smoothSolver;
        smoother        symGaussSeidel;
        tolerance       1e-7;
        relTol          0.01;
    }

    "(U|h|k|nuTilda)Final"
    {
        $U;
        relTol          0;
    }
}

PIMPLE
{
    momentumPredictor       yes;
    nOuterCorrectors        2;
    nCorrectors             2;
    nNonOrthogonalCorrectors 0;

    pMinFactor              0.5;
    pMaxFactor              2.0;
}

relaxationFactors
{
    equations
    {
        ".*" 1;
    }
}

